#!/usr/bin/env bash
# Build the offline Bazel sandbox image for Bugbot.
#
# GENERATED by `bugbot sandbox build`. Re-running the command regenerates it.
#
# Two phases:
#   1. Base image: {{.BaseImage}} + Bazel {{.BazelVersion}} + a system bazelrc,
#      with this repo's external deps baked in -- the `bazel vendor` tree at
#      {{.VendorMount}} and the content-addressed repository cache at
#      {{.RepoCacheMount}} (both supplied as build-time bind mounts; Bazel's
#      vendor mode must write inside the vendor dir, so it is baked as a layer
#      rather than mounted read-only).
#   2. Warm layer: run `bazel test --build_tests_only //...` once under
#      network=none to (a) prove the sandbox builds + tests fully offline and
#      (b) populate the disk cache at {{.DiskCacheMount}}, then commit it into
#      the final image. Baking the warm cache (vs mounting it) is required
#      because Bugbot mounts are read-only and Bazel disables a read-only disk
#      cache; an image layer is writable through the per-run container overlay,
#      so every Bugbot run starts warm.
#
# Re-run after re-vendoring; pass NO_CACHE=1 to force a clean base rebuild.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

IMAGE="${IMAGE:-{{.ImageTag}}}"
BASE_IMAGE="${BASE_IMAGE:-${IMAGE%:*}:base}"
RUNTIME="${RUNTIME:-{{.Runtime}}}"
REPO="${REPO:-{{.RepoDir}}}"
VENDOR_DIR="${VENDOR_DIR:-{{.VendorDir}}}"
REPO_CACHE="${REPO_CACHE:-{{if .RepoCachePath}}{{.RepoCachePath}}{{else}}$(cd "$REPO" && bazelisk info repository_cache 2>/dev/null){{end}}}"
NO_CACHE="${NO_CACHE:-0}"
WARM_CTR="bugbot-sandbox-warm"

if [ ! -d "$VENDOR_DIR" ]; then
    echo "!! vendor dir missing: $VENDOR_DIR" >&2
    echo "   run: bazel vendor --vendor_dir=$VENDOR_DIR //..." >&2
    exit 1
fi
if [ -z "$REPO_CACHE" ] || [ ! -d "$REPO_CACHE" ]; then
    echo "!! bazel repository cache not found (set REPO_CACHE=...): '$REPO_CACHE'" >&2
    exit 1
fi

build_args=(build -t "$BASE_IMAGE" -f "$HERE/Dockerfile" \
    -v "$VENDOR_DIR":/vendor-src:ro \
    -v "$REPO_CACHE":/repo-cache-src:ro)
[ "$NO_CACHE" = "1" ] && build_args+=(--no-cache)
build_args+=("$HERE")

echo ">> [1/2] building base image $BASE_IMAGE (baking vendor + repository cache)"
"$RUNTIME" "${build_args[@]}"

echo ">> [2/2] warming disk cache + offline smoke test (network=none)"
"$RUNTIME" rm -f "$WARM_CTR" >/dev/null 2>&1 || true
"$RUNTIME" run --name "$WARM_CTR" --network=none \
    -v "$REPO":/workspace:rw \
    "$BASE_IMAGE" \
    sh -c '{{.WarmTest}} --symlink_prefix=/root/bazel- && rm -rf /root/.cache/bazel'

echo ">> committing warm image $IMAGE"
"$RUNTIME" commit -q "$WARM_CTR" "$IMAGE" >/dev/null
"$RUNTIME" rm -f "$WARM_CTR" >/dev/null
"$RUNTIME" rmi "$BASE_IMAGE" >/dev/null 2>&1 || true

echo ">> sandbox image ready: $IMAGE"
