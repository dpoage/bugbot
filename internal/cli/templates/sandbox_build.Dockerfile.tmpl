# Offline Bazel sandbox image for Bugbot's verify/reproduce stages.
#
# GENERATED by `bugbot sandbox build` from the target repo's facts. Re-running
# the command regenerates it; hand edits are safe but will be overwritten.
#
# Bugbot runs `bazel test --build_tests_only //...` inside this image under
# network=none. Every external dep this repo needs is baked in as a vendor dir
# at {{.VendorMount}} (produced by `bazel vendor`; see build.sh). It is baked
# rather than bind-mounted because Bazel's vendor mode writes a
# {{.VendorMount}}/bazel-external symlink at run time, which a read-only mount
# rejects; an image layer is writable through the container overlay. A shared
# Bazel disk cache lives at {{.DiskCacheMount}} so unchanged targets are not
# recompiled on every run. The base image carries the host toolchain so
# compiler flags behave identically to the dev host.
FROM {{.BaseImage}}

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        git \
        zip \
        unzip \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ARG BAZEL_VERSION={{.BazelVersion}}
RUN curl -fsSL -o /usr/local/bin/bazel \
        "https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION}/bazel-${BAZEL_VERSION}-linux-x86_64" \
    && chmod +x /usr/local/bin/bazel

# Sandbox-only Bazel settings. /etc/bazel.bazelrc is the system rc, read before
# the workspace .bazelrc, so it applies to whatever command Bugbot invokes:
#   - vendor_dir: resolve external deps from the baked offline vendor tree
#   - repository_cache: serve extension-time downloads (e.g. rules_rust's
#     cargo-bazel generator binary) from the baked content-addressed cache
#   - disk_cache: reuse compiled artifacts across runs (cold builds are slow)
#   - lockfile_mode=error: honor MODULE.bazel.lock so extension results are
#     reused from the vendored repos instead of being re-evaluated (which would
#     run resolvers against the network); never writes the lockfile
#   - build_tests_only: `bazel test //...` builds test targets + deps only, so
#     host-incompatible targets (e.g. an arm64-only //docker:image) are not
#     analyzed under the host platform
RUN printf 'common --vendor_dir={{.VendorMount}}\ncommon --repository_cache={{.RepoCacheMount}}\ncommon --disk_cache={{.DiskCacheMount}}\ncommon --lockfile_mode=error\ntest --build_tests_only\n' \
        > /etc/bazel.bazelrc

# Bake the vendor tree and the content-addressed repository cache. Sources come
# through build-time bind mounts (`{{.Runtime}} build -v <dir>:/...-src:ro`, see
# build.sh). The stale vendor bazel-external symlink (points at the host output
# base) is dropped; Bazel recreates it per run in the writable overlay.
RUN mkdir -p {{.VendorMount}} {{.DiskCacheMount}} {{.RepoCacheMount}} \
    && cp -a /vendor-src/. {{.VendorMount}}/ \
    && cp -a /repo-cache-src/. {{.RepoCacheMount}}/ \
    && rm -f {{.VendorMount}}/bazel-external

ENV HOME=/root
WORKDIR /workspace
